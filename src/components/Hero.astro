---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import logo from "../images/logo.png";
import localImg from "../images/local.webp";
---

<!-- HERO: fondo verde lima con textura y elementos decorativos -->
<section
  id="inicio"
  class="hero-noise relative min-h-screen grid place-items-center overflow-hidden px-6 py-20"
  style="background-color: var(--color-verde);"
>
  <!-- Elementos decorativos SVG orgánicos -->
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none" aria-hidden="true">
    <!-- Espiral decorativa superior izquierda -->
    <svg class="absolute -top-10 -left-10 opacity-10 animate-float" width="260" height="260" viewBox="0 0 260 260" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M130 20 C170 20, 220 60, 220 110 C220 160, 170 200, 120 190 C70 180, 40 140, 50 100 C60 60, 100 50, 130 60 C160 70, 180 95, 170 120 C160 145, 135 150, 120 140" stroke="white" stroke-width="3" fill="none" stroke-linecap="round"/>
    </svg>
    <!-- Círculo decorativo inferior derecha -->
    <svg class="absolute -bottom-16 -right-16 opacity-10" width="320" height="320" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="160" cy="160" r="140" stroke="white" stroke-width="2" fill="none"/>
      <circle cx="160" cy="160" r="100" stroke="white" stroke-width="1.5" fill="none"/>
      <circle cx="160" cy="160" r="60" stroke="white" stroke-width="1" fill="none"/>
    </svg>
    <!-- Bambú / hoja derecha -->
    <svg class="absolute top-1/4 right-8 opacity-15 animate-float" style="animation-delay:1.5s" width="80" height="200" viewBox="0 0 80 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M40 195 C40 195, 38 150, 42 120 C46 90, 60 80, 55 55 C50 30, 35 20, 40 5" stroke="white" stroke-width="3" stroke-linecap="round" fill="none"/>
      <ellipse cx="60" cy="70" rx="22" ry="12" transform="rotate(-30 60 70)" fill="white" opacity="0.6"/>
      <ellipse cx="25" cy="110" rx="22" ry="12" transform="rotate(25 25 110)" fill="white" opacity="0.5"/>
    </svg>
  </div>

  <!-- Grid 2 columnas -->
  <div class="relative z-10 w-full max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Columna izquierda: contenido -->
    <div class="flex flex-col items-center lg:items-start text-center lg:text-left">

      <!-- Logo -->
      <div class="animate-fade-in-up mb-6">
        <Image
          src={logo}
          alt="Centro de Salud Esencia Vital"
          width="140"
          class="drop-shadow-lg"
        />
      </div>

      <!-- Headline -->
      <h1
        class="animate-fade-in-up-delay text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight mb-4"
        style="font-family: var(--font-display);"
      >
        Tu bienestar,<br />
        <span class="italic font-normal">en manos que cuidan</span>
      </h1>

      <!-- Subtítulo -->
      <p
        class="animate-fade-in-up-delay-2 text-white/90 text-lg md:text-xl max-w-xl mb-10 leading-relaxed"
        style="font-family: var(--font-body);"
      >
        Salud integral, natural y con amor.<br /> Encontrá el equilibrio que tu cuerpo y tu alma merecen.
      </p>

      <!-- CTA principal -->
      <a
        href="https://wa.me/50687736281"
        target="_blank"
        rel="noopener noreferrer"
        class="animate-fade-in-up-delay-2 inline-flex items-center gap-3 text-white font-bold text-lg px-8 py-4 rounded-full shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl active:scale-95"
        style="background-color: #25d366;"
      >
        <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor"><title>WhatsApp</title><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Escribinos por WhatsApp
      </a>
    </div>

    <!-- Columna derecha: imagen del local -->
    <div class="animate-fade-in-up-delay flex items-center justify-center">
      <div class="relative w-full max-w-lg">
        <Image
          src={localImg}
          alt="Interior del local Esencia Vital"
          class="w-full h-auto rounded-2xl shadow-2xl object-cover"
          widths={[400, 700]}
          sizes="(max-width: 1024px) 100vw, 50vw"
        />
        <!-- Borde decorativo -->
        <div class="absolute -inset-3 rounded-2xl border-2 border-white/20 -z-10"></div>
      </div>
    </div>

  </div>
</section>
